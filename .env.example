# Canonical site URL (no trailing slash). Used for sitemap, robots, OG, and JSON-LD.
# Example: https://www.jnjmanagementsolutions.com
NEXT_PUBLIC_SITE_URL=

# Optional: Team welcome video (embed URL, e.g. https://www.youtube.com/embed/VIDEO_ID). Omit to hide.
NEXT_PUBLIC_TEAM_VIDEO_URL=

# --- Contact form (SMTP) — server-only; add these in Vercel Project → Settings → Environment Variables
# Use your mailbox provider’s SMTP (Google Workspace, Microsoft 365, cPanel, etc.).
# Gmail: use an App Password, not your normal password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set to "true" only if your host requires implicit TLS on port 465
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Must usually match or be allowed for SMTP_USER (provider-dependent)
SMTP_FROM=
# Where inquiries should land (can be the same as SMTP_USER)
CONTACT_TO=

# Optional: where “schedule a call” requests go. If unset, uses CONTACT_TO.
BOOKING_TO=

# Optional: hero “Google reviews” link
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=

# Legacy: Tidio is no longer loaded by default (site uses the built-in founder chat panel).
# NEXT_PUBLIC_TIDIO_PUBLIC_KEY=
